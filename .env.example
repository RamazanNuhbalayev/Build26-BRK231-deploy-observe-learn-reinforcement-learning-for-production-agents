# Azure AI Foundry Project Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to git (it's in .gitignore)

# ─── Core Project Settings ───────────────────────────────────────────────────

# Project URL (format: https://{account}.services.ai.azure.com/api/projects/{project})
PROJECT_ENDPOINT=https://YOUR-ACCOUNT.services.ai.azure.com/api/projects/YOUR-PROJECT

# Tool Function App URL (the deployed retail-tools Azure Function)
TOOL_URL=https://YOUR-FUNCTION-APP.azurewebsites.net

# ─── Agent Deployment (used by deploy/src/retail-*/main.py) ───────────────

# Azure OpenAI endpoint (auto-configured by azd, override for local testing)
# AZURE_OPENAI_ENDPOINT=https://YOUR-ACCOUNT.services.ai.azure.com

# Foundry project endpoint (alternative to AZURE_OPENAI_ENDPOINT)
# FOUNDRY_PROJECT_ENDPOINT=https://YOUR-ACCOUNT.services.ai.azure.com/api/projects/YOUR-PROJECT

# Model deployment name (each agent has its own default)
# AZURE_AI_MODEL_DEPLOYMENT_NAME=o4-mini

# ─── Scripts (download_eval_results.py, llm_grader.py, local_eval_run.py) ────

# API key for inference (if not using DefaultAzureCredential)
# INFERENCE_API_KEY=your-api-key-here

# Inference endpoint (defaults to PROJECT_ENDPOINT)
# INFERENCE_ENDPOINT=https://YOUR-ACCOUNT.services.ai.azure.com

# API version for Azure OpenAI calls
# API_VERSION=2024-12-01-preview

# ─── Authentication ──────────────────────────────────────────────────────────
# All tools use DefaultAzureCredential by default (az login).
# Set API keys below only if not using Azure CLI authentication.
# AGENT_API_KEY=your-api-key-here
